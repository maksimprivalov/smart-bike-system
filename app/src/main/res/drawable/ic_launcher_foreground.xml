<?xml version="1.0" encoding="utf-8"?>
<!--
  Bicycle icon for SmartBike app.
  Viewport 108x108. Bike centered at ~(54, 60).
  Left wheel: center (32, 68), Right wheel: center (76, 68), radius 18.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Left wheel (stroke) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"
        android:fillColor="#00000000"
        android:pathData="M32,68 m-18,0 a18,18 0 1,0 36,0 a18,18 0 1,0 -36,0" />

    <!-- Right wheel (stroke) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"
        android:fillColor="#00000000"
        android:pathData="M76,68 m-18,0 a18,18 0 1,0 36,0 a18,18 0 1,0 -36,0" />

    <!-- Frame: chainstay + seat tube + seat stay -->
    <!-- chainstay: rear hub (32,68) → BB (54,68) -->
    <!-- seat tube: BB (54,68) → seat cluster (50,42) -->
    <!-- seat stay: rear hub (32,68) → seat cluster (50,42) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M32,68 L54,68 L50,42 L32,68" />

    <!-- Down tube + head tube area -->
    <!-- down tube: BB (54,68) → head tube bottom (74,52) -->
    <!-- head tube: (74,52) → (72,42) -->
    <!-- top tube: seat cluster (50,42) → head tube top (72,42) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M54,68 L74,52 L72,42 L50,42" />

    <!-- Fork: head tube bottom (74,52) → front hub (76,68) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M74,52 L76,68" />

    <!-- Seat post: (50,42) → (50,34) + saddle: (44,34)–(58,34) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M50,42 L50,34 M44,34 L58,34" />

    <!-- Handlebar stem: head tube top (72,42) → (72,34) + bar: (66,34)–(80,34) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M72,42 L72,34 M66,34 L80,34 L80,28" />

    <!-- Rider head (filled circle, above handlebar) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M72,22 m-7,0 a7,7 0 1,0 14,0 a7,7 0 1,0 -14,0" />

</vector>
